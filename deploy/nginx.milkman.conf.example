server {
    listen 80;
    server_name your-domain.com www.your-domain.com;

    client_max_body_size 20m;

    # React build output
    root /var/www/milkman/frontend-app/dist;
    index index.html;

    # Frontend static assets from Vite build
    location /assets/ {
        try_files $uri =404;
        access_log off;
        expires 1y;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # Optional static/media if you choose to let Nginx serve them directly
    location /static/ {
        alias /var/www/milkman/staticfiles/;
        access_log off;
        expires 30d;
    }

    location /media/ {
        alias /var/www/milkman/media/;
        access_log off;
        expires 30d;
    }

    # Django backend routes
    location /api/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /admin/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Single-page app fallback so direct links like /products work
    location / {
        try_files $uri /index.html;
    }
}
